# Whisper installation — secrets & runtime config.
# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Loaded by server.js at startup. Real shell/systemd env vars override these.

# ElevenLabs — required for whisper sound generation.
# Create a key: https://elevenlabs.io/docs/api-reference/service-accounts/api-keys/create
ELEVENLABS_API_KEY=
# Voice ID from your ElevenLabs voice library (Voices → … → Copy voice ID)
ELEVENLABS_VOICE_ID=

# Optional
# PORT=3000
# WHISPER_CONFIG_PATH=/etc/whisper/config.json
